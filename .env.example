# DonDone environment template
# Copy this file to `.env` and set every required value explicitly.
# Do not commit real secrets.

# ===================================
# Shared Runtime
# Used by docker-compose.yml deploy/runtime services
# ===================================
POSTGRES_DB=dondone
POSTGRES_USER=
POSTGRES_PASSWORD=

REDIS_PASSWORD=

JWT_SECRET=
JWT_ACCESS_EXPIRATION_MS=86400000

# Choose explicitly for the target environment.
# Example: demo (presentation) / prod (service operation)
SPRING_PROFILES_ACTIVE=

# Optional override. Leave blank to reuse REMITTANCE_WALLET_ENCRYPTION_KEY.
EMPLOYER_SIGNUP_CODE_ENCRYPTION_KEY=

# ===================================
# Remittance Runtime
# Set explicitly for the target chain/environment
# ===================================
# Example: sepolia
REMITTANCE_CHAIN_MODE=
REMITTANCE_CHAIN_RPC_URL=
REMITTANCE_CHAIN_ID=11155111
REMITTANCE_TOKEN_ADDRESS=

# Vault runtime
# Example: demo / sepolia
VAULT_CHAIN_MODE=
VAULT_TOKEN_ADDRESS=
VAULT_ADDRESS=

REMITTANCE_TREASURY_PRIVATE_KEY=
REMITTANCE_WALLET_ENCRYPTION_KEY=
REMITTANCE_WALLET_FUNDING_RECEIPT_TIMEOUT_SECONDS=60
REMITTANCE_WALLET_FUNDING_PENDING_STALE_SECONDS=300
REMITTANCE_ASSET_SYMBOL=dUSDC
REMITTANCE_ASSET_DECIMALS=6
REMITTANCE_HIGH_AMOUNT_THRESHOLD_ATOMIC=300000000
REMITTANCE_RECENT_RECIPIENT_WINDOW_SECONDS=86400
REMITTANCE_MAX_AUTO_RETRY_COUNT=2
REMITTANCE_DEFAULT_LIST_LIMIT=20
REMITTANCE_WORKER_POLL_INTERVAL_MS=2000
REMITTANCE_RECEIPT_POLL_DELAY_SECONDS=2
REMITTANCE_RECEIPT_TIMEOUT_SECONDS=300
REMITTANCE_TOKEN_GAS_LIMIT=120000
REMITTANCE_NATIVE_TRANSFER_GAS_LIMIT=21000
REMITTANCE_INITIAL_TOKEN_AMOUNT_ATOMIC=50000000
REMITTANCE_INITIAL_NATIVE_AMOUNT_WEI=10000000000000000

# ===================================
# Web Build-Time Variables
# Used only when building apps/dondone-web
# ===================================
VITE_KAKAO_MAP_APP_KEY=
# Leave blank in production when nginx provides same-origin /api.
VITE_API_BASE_URL=

# ===================================
# Local Development Only
# Used by docker-compose.dev.yml
# ===================================
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=dondone-local
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
