# ===================================
# PostgreSQL
# ===================================
POSTGRES_DB=dondone
POSTGRES_USER=
POSTGRES_PASSWORD=

# ===================================
# Redis
# ===================================
REDIS_PASSWORD=

# ===================================
# JWT
# ===================================
JWT_SECRET=
JWT_ACCESS_EXPIRATION_MS=86400000

# ===================================
# Spring
# ===================================
SPRING_PROFILES_ACTIVE=demo

# ===================================
# Remittance
# ===================================
REMITTANCE_CHAIN_MODE=demo
REMITTANCE_CHAIN_RPC_URL=
REMITTANCE_CHAIN_ID=11155111
REMITTANCE_TOKEN_ADDRESS=
REMITTANCE_TREASURY_PRIVATE_KEY=
REMITTANCE_WALLET_ENCRYPTION_KEY=
REMITTANCE_WALLET_FUNDING_RECEIPT_TIMEOUT_SECONDS=60
REMITTANCE_WALLET_FUNDING_PENDING_STALE_SECONDS=300
REMITTANCE_ASSET_SYMBOL=dUSDC
REMITTANCE_ASSET_DECIMALS=6
REMITTANCE_HIGH_AMOUNT_THRESHOLD_ATOMIC=100000000
REMITTANCE_RECENT_RECIPIENT_WINDOW_SECONDS=86400
REMITTANCE_MAX_AUTO_RETRY_COUNT=2
REMITTANCE_DEFAULT_LIST_LIMIT=20
REMITTANCE_WORKER_POLL_INTERVAL_MS=2000
REMITTANCE_RECEIPT_POLL_DELAY_SECONDS=2
REMITTANCE_RECEIPT_TIMEOUT_SECONDS=300
REMITTANCE_TOKEN_GAS_LIMIT=120000
REMITTANCE_NATIVE_TRANSFER_GAS_LIMIT=21000
REMITTANCE_INITIAL_TOKEN_AMOUNT_ATOMIC=500000000
REMITTANCE_INITIAL_NATIVE_AMOUNT_WEI=10000000000000000

# ===================================
# Local Dev MinIO (docker-compose.dev.yml only)
# ===================================
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=dondone-local
